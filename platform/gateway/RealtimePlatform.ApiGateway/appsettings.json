{
  "ForwardedHeaders": {
    "Enabled": false,
    "ForwardLimit": 2,
    "RequireHeaderSymmetry": false,
    "TrustIngressNetwork": false
  },
  "Aspire": {
    "AppHostProject": "platform/RealtimePlatform.AppHost/RealtimePlatform.AppHost.csproj",
    "Remarks": "Under AppHost, ReverseProxy cluster primary Address values are overridden via environment (see AppHost WithEnvironment). Base ReverseProxy uses in-mesh host names with explicit Kestrel ports 5001-5017.",
    "Docs": "docs/ASPIRE-APPSETTINGS.md"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Authentication": {
    "JwtBearer": {
      "Authority": "",
      "Audience": "api://dialysis-pdms",
      "DevelopmentBypass": false
    }
  },
  "Authorization": {
    "Scopes": {
      "DevicesRead": "Dialysis.Devices.Read",
      "DevicesWrite": "Dialysis.Devices.Write",
      "MeasurementsRead": "Dialysis.Measurements.Read",
      "MeasurementsWrite": "Dialysis.Measurements.Write",
      "SessionsRead": "Dialysis.Sessions.Read",
      "SessionsWrite": "Dialysis.Sessions.Write",
      "AuditRead": "Dialysis.Audit.Read",
      "AuditWrite": "Dialysis.Audit.Write",
      "ValidationRead": "Dialysis.Validation.Read",
      "ValidationWrite": "Dialysis.Validation.Write",
      "ConditioningRead": "Dialysis.Conditioning.Read",
      "ConditioningWrite": "Dialysis.Conditioning.Write",
      "TerminologyRead": "Dialysis.Terminology.Read",
      "TerminologyWrite": "Dialysis.Terminology.Write",
      "InteroperabilityRead": "Dialysis.Interoperability.Read",
      "InteroperabilityWrite": "Dialysis.Interoperability.Write",
      "ReadModelRead": "Dialysis.ReadModel.Read",
      "ReadModelWrite": "Dialysis.ReadModel.Write",
      "SurveillanceRead": "Dialysis.Surveillance.Read",
      "SurveillanceWrite": "Dialysis.Surveillance.Write",
      "DeliveryRead": "Dialysis.Delivery.Read",
      "DeliveryWrite": "Dialysis.Delivery.Write",
      "AnalyticsRead": "Dialysis.Analytics.Read",
      "AnalyticsWrite": "Dialysis.Analytics.Write",
      "ReportingRead": "Dialysis.Reporting.Read",
      "ReportingWrite": "Dialysis.Reporting.Write",
      "WorkflowRead": "Dialysis.Workflow.Read",
      "WorkflowWrite": "Dialysis.Workflow.Write",
      "ReplayRead": "Dialysis.Replay.Read",
      "ReplayWrite": "Dialysis.Replay.Write",
      "ConfigurationRead": "Dialysis.Configuration.Read",
      "ConfigurationWrite": "Dialysis.Configuration.Write",
      "FinancialRead": "Dialysis.Financial.Read",
      "FinancialWrite": "Dialysis.Financial.Write"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "r-realtime-hubs": {
        "ClusterId": "realtime-delivery",
        "Order": 0,
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      },
      "r-measurement-validation": {
        "ClusterId": "measurement-validation",
        "Order": 1,
        "Match": {
          "Path": "/api/v{version}/measurements/{measurementId}/validation/{**catch-all}"
        }
      },
      "r-measurement-conditioning": {
        "ClusterId": "signal-conditioning",
        "Order": 2,
        "Match": {
          "Path": "/api/v{version}/measurements/{measurementId}/conditioning/{**catch-all}"
        }
      },
      "r-measurement-canonical": {
        "ClusterId": "clinical-interoperability",
        "Order": 3,
        "Match": {
          "Path": "/api/v{version}/measurements/{measurementId}/canonical-observation/{**catch-all}"
        }
      },
      "r-device-registry-root": {
        "ClusterId": "device-registry",
        "Order": 8,
        "Match": {
          "Path": "/api/v{version}/devices"
        }
      },
      "r-alerts-readmodel-root": {
        "ClusterId": "query-read-model",
        "Order": 9,
        "Match": {
          "Path": "/api/v{version}/alerts"
        }
      },
      "r-measurement-acquisition-root": {
        "ClusterId": "measurement-acquisition",
        "Order": 10,
        "Match": {
          "Path": "/api/v{version}/measurements"
        }
      },
      "r-measurement-acquisition": {
        "ClusterId": "measurement-acquisition",
        "Order": 11,
        "Match": {
          "Path": "/api/v{version}/measurements/{**catch-all}"
        }
      },
      "r-session-readmodel-overview": {
        "ClusterId": "query-read-model",
        "Order": 15,
        "Match": {
          "Path": "/api/v{version}/sessions/{sessionId}/overview"
        }
      },
      "r-financial-interoperability": {
        "ClusterId": "financial-interoperability",
        "Order": 19,
        "Match": {
          "Path": "/api/v{version}/financial/{**catch-all}"
        }
      },
      "r-treatment-session": {
        "ClusterId": "treatment-session",
        "Order": 20,
        "Match": {
          "Path": "/api/v{version}/sessions/{**catch-all}"
        }
      },
      "r-device-registry": {
        "ClusterId": "device-registry",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/devices/{**catch-all}"
        }
      },
      "r-audit": {
        "ClusterId": "audit-provenance",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/audit/{**catch-all}"
        }
      },
      "r-terminology": {
        "ClusterId": "terminology-conformance",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/resources/{**catch-all}"
        }
      },
      "r-publications": {
        "ClusterId": "clinical-interoperability",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/publications/{**catch-all}"
        }
      },
      "r-dashboard": {
        "ClusterId": "query-read-model",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/dashboard/{**catch-all}"
        }
      },
      "r-alerts-readmodel": {
        "ClusterId": "query-read-model",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/alerts/{**catch-all}"
        }
      },
      "r-projections": {
        "ClusterId": "query-read-model",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/projections/{**catch-all}"
        }
      },
      "r-surveillance": {
        "ClusterId": "realtime-surveillance",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/surveillance/{**catch-all}"
        }
      },
      "r-delivery": {
        "ClusterId": "realtime-delivery",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/delivery/{**catch-all}"
        }
      },
      "r-clinical-analytics": {
        "ClusterId": "clinical-analytics",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/clinical-analytics/{**catch-all}"
        }
      },
      "r-reporting": {
        "ClusterId": "reporting",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/reporting/{**catch-all}"
        }
      },
      "r-workflow": {
        "ClusterId": "workflow-orchestrator",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/workflow-orchestrator/{**catch-all}"
        }
      },
      "r-replay-recovery": {
        "ClusterId": "replay-recovery",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/replay-recovery/{**catch-all}"
        }
      },
      "r-administration-configuration": {
        "ClusterId": "administration-configuration",
        "Order": 30,
        "Match": {
          "Path": "/api/v{version}/administration-configuration/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "device-registry": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://device-registry:5001/"
          }
        }
      },
      "measurement-acquisition": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://measurement-acquisition:5002/"
          }
        }
      },
      "treatment-session": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://treatment-session:5003/"
          }
        }
      },
      "audit-provenance": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://audit-provenance:5004/"
          }
        }
      },
      "measurement-validation": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://measurement-validation:5005/"
          }
        }
      },
      "signal-conditioning": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://signal-conditioning:5006/"
          }
        }
      },
      "terminology-conformance": {
