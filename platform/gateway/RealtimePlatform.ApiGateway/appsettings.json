            "Address": "http://terminology-conformance:5007/"
          }
        }
      },
      "clinical-interoperability": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://clinical-interoperability:5008/"
          }
        }
      },
      "query-read-model": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://query-read-model:5009/"
          }
        }
      },
      "realtime-surveillance": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://realtime-surveillance:5010/"
          }
        }
      },
      "realtime-delivery": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:30:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://realtime-delivery:5011/"
          }
        }
      },
      "clinical-analytics": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://clinical-analytics:5012/"
          }
        }
      },
      "reporting": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://reporting:5013/"
          }
        }
      },
      "workflow-orchestrator": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://workflow-orchestrator:5014/"
          }
        }
      },
      "replay-recovery": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        },
        "Destinations": {
          "primary": {
            "Address": "http://replay-recovery:5015/"
          }
        }
      },
      "administration-configuration": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": {
