# YARP API gateway origin (trailing slash optional). Production must be HTTPS.
# Production / Docker (nginx): same-origin API paths when true (see docker-compose pdms-web build).
# VITE_SAME_ORIGIN_API=true

# Dev: if omitted, the Vite dev server proxies /health, /api, and /hubs (WebSocket) to http://localhost:5100.
# Set this to call the gateway directly from the browser (CORS allows localhost in Development).
# VITE_API_BASE_URL=http://localhost:5100

# C5 tenant header sent as X-Tenant-Id on every API request.
# Must match Simulation.GatewayCli: --tenant or SIMULATION_GATEWAY_TENANT (default often "default").
# VITE_APP_TENANT_ID=default

# API path version segment (default 1).
# VITE_API_VERSION=1

# Development only: comma-separated UI role hints for RoleGate (not authorization).
# For simulator + realtime demo: include readmodel.read (GET /alerts, summary) and delivery.read (SignalR panels).
# VITE_APP_ROLES=readmodel.read,delivery.read,financial.read,clinical.read,admin

# Development only: map platform JWT scopes to UI roles (see src/auth/dialysisScopeMap.ts).
# VITE_DIALYSIS_SCOPES=Dialysis.ReadModel.Read,Dialysis.Financial.Read,Dialysis.Interoperability.Read
